<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Control de Parqueadero"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A73E8"
                android:layout_marginBottom="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Placa del Vehículo"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtPlaca"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAllCaps="true"
                            android:inputType="textCapCharacters"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnEntrada"
                        android:text="REGISTRAR ENTRADA"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="#34A853"
                        android:textColor="#FFFFFF"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        app:cornerRadius="8dp"/>

                    <Button
                        android:id="@+id/btnSalida"
                        android:text="CALCULAR COBRO / SALIDA"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#EA4335"
                        android:textColor="#FFFFFF"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        app:cornerRadius="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResultadoPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="10dp"
                app:strokeColor="#34A853"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF">

                    <TextView
                        android:text="RESUMEN DE COBRO"
                        android:textStyle="bold"
                        android:textColor="#34A853"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#DDDDDD"
                        android:layout_marginVertical="15dp"/>

                    <TextView
                        android:id="@+id/txtDetallePago"
                        android:text="Calculando..."
                        android:textSize="17sp"
                        android:textColor="#3C4043"
                        android:lineSpacingExtra="6dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <Button
                        android:id="@+id/btnConfirmarPago"
                        android:text="CONFIRMAR PAGO Y SALIDA"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="#34A853"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>